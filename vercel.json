{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "cleanUrls": true,
  "rewrites": [
    {
      "source": "/arena",
      "destination": "/arena/index.html"
    },
    {
      "source": "/arena/",
      "destination": "/arena/index.html"
    },
    {
      "source": "/produtos",
      "destination": "/produtos/index.html"
    },
    {
      "source": "/produtos/",
      "destination": "/produtos/index.html"
    }
  ]
}
