{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "rewrites": [
    {
      "source": "/produtos",
      "destination": "/produtos/index.html"
    },
    {
      "source": "/produtos/:path*",
      "destination": "/produtos/index.html"
    },
    {
      "source": "/arena",
      "destination": "/arena/index.html"
    },
    {
      "source": "/arena/:path*",
      "destination": "/arena/index.html"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
