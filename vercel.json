{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "cleanUrls": true,
  "rewrites": [
    {
      "source": "/arena",
      "destination": "/arena/index.html"
    },
    {
      "source": "/arena/",
      "destination": "/arena/index.html"
    },
    {
      "source": "/produtos",
      "destination": "/produtos/index.html"
    },
    {
      "source": "/produtos/",
      "destination": "/produtos/index.html"
    },
    {
      "source": "/admin",
      "destination": "/index.html"
    },
    {
      "source": "/admin/",
      "destination": "/index.html"
    },
    {
      "source": "/admin/login",
      "destination": "/index.html"
    },
    {
      "source": "/admin/produtos",
      "destination": "/index.html"
    },
    {
      "source": "/admin/produtos/novo",
      "destination": "/index.html"
    },
    {
      "source": "/admin/produtos/editar/:id",
      "destination": "/index.html"
    },
    {
      "source": "/admin/categorias",
      "destination": "/index.html"
    },
    {
      "source": "/admin/arena",
      "destination": "/index.html"
    },
    {
      "source": "/admin/configuracoes",
      "destination": "/index.html"
    },
    {
      "source": "/admin/(.*)",
      "destination": "/index.html"
    }
  ]
}
